<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_loai_van_ban_form" model="ir.ui.view">
            <field name="name">loai_van_ban.form</field>
            <field name="model">loai_van_ban</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ten_loai" placeholder="Tên loại văn bản"/>
                            </h1>
                        </div>
                        <group col="2" string="Thông tin loại văn bản">
                            <field name="ma_loai"/>
                            <field name="active"/>
                        </group>
                        <group string="Mô tả">
                            <field name="mo_ta" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_loai_van_ban_tree" model="ir.ui.view">
            <field name="name">loai_van_ban.tree</field>
            <field name="model">loai_van_ban</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_loai"/>
                    <field name="ten_loai"/>
                    <field name="mo_ta"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_loai_van_ban_search" model="ir.ui.view">
            <field name="name">loai_van_ban.search</field>
            <field name="model">loai_van_ban</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_loai"/>
                    <field name="ten_loai"/>
                    <filter string="Hoạt động" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Không hoạt động" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_loai_van_ban" model="ir.actions.act_window">
            <field name="name">Loại văn bản</field>
            <field name="res_model">loai_van_ban</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_loai_van_ban_search"/>
        </record>
    </data>
</odoo>
