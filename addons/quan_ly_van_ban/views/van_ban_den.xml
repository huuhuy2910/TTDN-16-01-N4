<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_van_ban_den_form" model="ir.ui.view">
            <field name="name">van_ban_den.form</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <form>
                    <!-- Header removed: trạng thái chỉnh trong form bằng dropdown -->
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="so_van_ban" placeholder="Số văn bản"/>
                            </h1>
                        </div>
                        <group col="2">
                            <group string="Thông tin văn bản">
                                <field name="trich_yeu"/>
                                <field name="loai_van_ban_id"/>
                                <field name="ngay_van_ban"/>
                                <field name="ngay_den"/>
                            </group>
                            <group string="Thông tin khác">
                                <field name="co_quan_ban_hanh"/>
                                <field name="nguoi_ky"/>
                                <field name="so_trang"/>
                            </group>
                        </group>
                        <group string="Trạng thái">
                            <field name="trang_thai"/>
                        </group>
                        <group string="File đính kèm">
                            <field name="file_dinh_kem" filename="ten_file"/>
                            <field name="ten_file" invisible="1"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_van_ban_den_tree" model="ir.ui.view">
            <field name="name">van_ban_den.tree</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="so_van_ban"/>
                    <field name="trich_yeu"/>
                    <field name="loai_van_ban_id"/>
                    <field name="ngay_den"/>
                    <field name="co_quan_ban_hanh"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_van_ban_den_search" model="ir.ui.view">
            <field name="name">van_ban_den.search</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <search>
                    <field name="so_van_ban"/>
                    <field name="trich_yeu"/>
                    <field name="loai_van_ban_id"/>
                    <field name="co_quan_ban_hanh"/>
                    <filter string="Mới" name="moi" domain="[('trang_thai', '=', 'moi')]"/>
                    <filter string="Đang xử lý" name="dang_xu_ly" domain="[('trang_thai', '=', 'dang_xu_ly')]"/>
                    <filter string="Đã xử lý" name="da_xu_ly" domain="[('trang_thai', '=', 'da_xu_ly')]"/>
                    <filter string="Lưu trữ" name="luu_tru" domain="[('trang_thai', '=', 'luu_tru')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Loại văn bản" name="group_loai" context="{'group_by': 'loai_van_ban_id'}"/>
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                        <filter string="Ngày đến" name="group_ngay_den" context="{'group_by': 'ngay_den'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_van_ban_den" model="ir.actions.act_window">
            <field name="name">Văn bản đến</field>
            <field name="res_model">van_ban_den</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_van_ban_den_search"/>
        </record>
    </data>
</odoo>
